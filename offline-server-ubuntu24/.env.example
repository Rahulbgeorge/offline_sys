# Use this file to define your environment variables
# Copy this file to .env before running install.sh

# The tunnel token provided by Cloudflare
CLOUDFLARED_TOKEN=your_token_here

# Optional: The domain name if you are setting up host-specific configs
HOST_DOMAIN=localhost

# The domain to which the agent will publish metrics
AGENT_DOMAIN=192.168.29.142:8000

# Agent Authentication & Identity
AGENT_TENANT_ID=default-tenant
AGENT_API_KEY=test-key-123
# AGENT_API_PASSWORD=your_password_here
AGENT_INTERVAL=60
