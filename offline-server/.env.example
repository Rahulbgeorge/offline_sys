# Global Environment Variables expected across scripts

# Loki Configuration for Grafana Alloy
LOKI_URL=http://loki-server:3100/loki/api/v1/push
LOKI_USERNAME=my_loki_user
LOKI_PASSWORD=my_loki_password
LOKI_TENANT_ID=offline_tenant_1

# Prometheus Configuration
PROMETHEUS_URL=http://prometheus-server:9090/api/v1/write
PROMETHEUS_USERNAME=my_prom_user
PROMETHEUS_PASSWORD=my_prom_pass

# Host domain for SSH / Cloudflared tunnel
HOST_DOMAIN=sumangali.offlinesys.shop
CLOUDFLARED_TOKEN_NAME=my_tunnel_token
